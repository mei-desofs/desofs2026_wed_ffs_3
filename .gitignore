project/target/
project/package-lock.json
*.class

# Secrets — never commit real credentials
.env
.env.local
application-local.properties
application-prod.properties

# IDE / build server artefacts (Metals, Bloop)
.metals/
.bloop/
project/.bloop/
*.mv.db

# Self-signed TLS certs for local dev — never commit
deploy/nginx/certs/*.crt
deploy/nginx/certs/*.key
!deploy/nginx/certs/.gitkeep
