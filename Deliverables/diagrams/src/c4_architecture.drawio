  <diagram id="c2-container" name="C2 - Containers">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1050" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title-c2" value="&lt;b&gt;C2 - Container Diagram: Coffeetaria&lt;/b&gt;&lt;br&gt;Runtime containers from Docker Compose and application configuration." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=20;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="60" y="40" width="880" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="api-consumers-c2" value="&lt;b&gt;API Consumers&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Client, employee and admin users through web/mobile/direct API clients&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;fontColor=#ffffff;strokeColor=#052E56;fontSize=14;arcSize=8;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="250" width="230" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="host-boundary-c2" value="&lt;b&gt;Docker Compose Runtime&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#666666;dashed=1;dashPattern=8 4;fontColor=#555555;align=left;verticalAlign=top;spacing=8;container=1;recursiveResize=0;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="390" y="140" width="860" height="690" as="geometry"/>
        </mxCell>
        <mxCell id="nginx-c2" value="&lt;b&gt;Reverse Proxy&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Nginx 1.27 Alpine&lt;br&gt;TLS termination, HTTP to HTTPS redirect, HSTS&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E6295;fontSize=14;arcSize=8;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="470" y="250" width="270" height="125" as="geometry"/>
        </mxCell>
        <mxCell id="app-c2" value="&lt;b&gt;Application Container&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Spring Boot REST API&lt;br&gt;Java 17 / Spring Boot 3.5.14&lt;br&gt;Port 8081 exposed only inside Compose network&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E6295;fontSize=14;arcSize=8;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="235" width="300" height="155" as="geometry"/>
        </mxCell>
        <mxCell id="postgres-c2" value="&lt;b&gt;Database Container&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;PostgreSQL 16 Alpine&lt;br&gt;Database: cafeteriadb&lt;br&gt;Volume: postgres_data&lt;/font&gt;" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E6295;fontSize=14;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="855" y="520" width="300" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="files-c2" value="&lt;b&gt;Application Files Volume&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Docker volume: app_files&lt;br&gt;Mounted at /app/files&lt;br&gt;Base dir controlled by APP_FILESYSTEM_BASE_DIR&lt;/font&gt;" style="shape=folder;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E6295;fontSize=14;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="475" y="535" width="285" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="hibp-c2" value="&lt;b&gt;Pwned Passwords API&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;External HTTPS service&lt;br&gt;api.pwnedpasswords.com/range/{prefix}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#6B6B6B;fontSize=14;arcSize=8;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1370" y="250" width="260" height="125" as="geometry"/>
        </mxCell>
        <mxCell id="note-c2" value="&lt;b&gt;Container responsibilities&lt;/b&gt;&lt;br&gt;Nginx enforces secure channel at the edge. The Spring Boot app remains stateless and validates JWTs per request. PostgreSQL and file storage are private infrastructure containers/volumes." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="580" width="260" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="edge-consumers-nginx" value="HTTPS :443&lt;br&gt;HTTP :80 redirects to HTTPS" style="endArrow=block;html=1;rounded=0;strokeColor=#333333;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="api-consumers-c2" target="nginx-c2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge-nginx-app" value="Proxies HTTP to app:8081&lt;br&gt;adds X-Forwarded-* headers" style="endArrow=block;html=1;rounded=0;strokeColor=#333333;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="nginx-c2" target="app-c2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge-app-postgres" value="JDBC / JPA&lt;br&gt;jdbc:postgresql://postgres:5432/cafeteriadb" style="endArrow=block;html=1;rounded=0;strokeColor=#333333;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="app-c2" target="postgres-c2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge-app-files" value="java.nio file operations&lt;br&gt;safe path resolution" style="endArrow=block;html=1;rounded=0;strokeColor=#333333;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="app-c2" target="files-c2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge-app-hibp" value="HTTPS GET&lt;br&gt;password breach range check" style="endArrow=block;html=1;rounded=0;strokeColor=#333333;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="app-c2" target="hibp-c2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="c3-components" name="C3 - Backend Components">
