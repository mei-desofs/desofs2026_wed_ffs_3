        <mxCell id="code-audit" value="&lt;b&gt;SecurityAuditLogger&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Logs authentication success/failure, blocked attempts, token failures and access denied events.&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;fontColor=#111111;strokeColor=#B85450;fontSize=13;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="675" width="250" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="code-password-policy" value="&lt;b&gt;PasswordPolicyService&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Validates password strength before user creation/update.&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;fontColor=#111111;strokeColor=#B85450;fontSize=13;spacing=10;" vertex="1" parent="1">
