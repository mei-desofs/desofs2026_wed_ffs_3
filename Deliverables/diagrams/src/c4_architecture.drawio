        <mxCell id="code-jwt-util" value="&lt;b&gt;JwtTokenUtil&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Creates and validates HS256 JWTs.&lt;br&gt;Claims include subject, role, issued-at and expiration.&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;fontColor=#111111;strokeColor=#B85450;fontSize=13;spacing=10;" vertex="1" parent="1">
