        <mxCell id="edge-system-hibp" value="Checks password SHA-1 prefix&lt;br&gt;HTTPS k-anonymity lookup" style="endArrow=block;html=1;rounded=0;strokeColor=#333333;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="system-coffeetaria" target="external-hibp">
