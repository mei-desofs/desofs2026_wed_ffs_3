        <mxCell id="code-hibp" value="&lt;b&gt;HaveIBeenPwnedClient&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Checks SHA-1 password prefix with Pwned Passwords range API. Fails open on API errors.&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;fontColor=#111111;strokeColor=#B85450;fontSize=13;spacing=10;" vertex="1" parent="1">
