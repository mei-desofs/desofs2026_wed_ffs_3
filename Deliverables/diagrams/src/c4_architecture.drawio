        <mxCell id="edge-client-system" value="Uses HTTPS REST API&lt;br&gt;JWT bearer token after login" style="endArrow=block;html=1;rounded=0;strokeColor=#333333;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="person-client" target="system-coffeetaria">
          <mxGeometry relative="1" as="geometry"/>
