        <mxCell id="edge-employee-system" value="Uses HTTPS REST API&lt;br&gt;role-based operations" style="endArrow=block;html=1;rounded=0;strokeColor=#333333;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="person-employee" target="system-coffeetaria">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge-admin-system" value="Uses HTTPS REST API&lt;br&gt;administration operations" style="endArrow=block;html=1;rounded=0;strokeColor=#333333;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="person-admin" target="system-coffeetaria">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge-system-db" value="Reads/writes domain data&lt;br&gt;JPA / SQL" style="endArrow=block;html=1;rounded=0;strokeColor=#333333;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="system-coffeetaria" target="store-postgres-c1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge-system-files" value="Reads/writes files&lt;br&gt;validated relative paths" style="endArrow=block;html=1;rounded=0;strokeColor=#333333;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="system-coffeetaria" target="store-files-c1">
          <mxGeometry relative="1" as="geometry"/>
