          <mxGeometry x="370" y="125" width="1050" height="870" as="geometry"/>
        </mxCell>
        <mxCell id="security-c3" value="&lt;b&gt;Security Layer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;SecurityConfig, JwtRequestFilter, JwtTokenUtil, TokenBlocklist, SimpleRateLimiter, SecurityAuditLogger&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#111111;strokeColor=#4D86B8;fontSize=13;arcSize=8;spacing=10;" vertex="1" parent="1">
