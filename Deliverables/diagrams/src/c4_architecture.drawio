        <mxCell id="edge-security-controllers" value="Authenticates request&lt;br&gt;enforces route-level RBAC" style="endArrow=block;html=1;rounded=0;strokeColor=#333333;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="security-c3" target="controllers-c3">
