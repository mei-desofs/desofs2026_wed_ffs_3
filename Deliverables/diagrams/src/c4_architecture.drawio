        <mxCell id="external-hibp" value="&lt;b&gt;Have I Been Pwned&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Pwned Passwords range API&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#6B6B6B;fontSize=14;arcSize=8;spacing=10;" vertex="1" parent="1">
