        </mxCell>
        <mxCell id="code-blocklist" value="&lt;b&gt;TokenBlocklist&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;In-memory token revocation map.&lt;br&gt;Entries expire at JWT expiry time.&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;fontColor=#111111;strokeColor=#B85450;fontSize=13;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="890" y="665" width="250" height="105" as="geometry"/>
