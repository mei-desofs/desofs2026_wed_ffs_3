        <mxCell id="store-files-c1" value="&lt;b&gt;Sandboxed File Storage&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Reports, operational files and audit logs&lt;/font&gt;" style="shape=folder;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E6295;fontSize=13;spacing=8;" vertex="1" parent="1">
