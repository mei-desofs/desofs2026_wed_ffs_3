        <mxCell id="postgres-c3" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Relational domain data&lt;/font&gt;" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E6295;fontSize=13;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1290" y="805" width="220" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="files-c3" value="&lt;b&gt;Filesystem Base Directory&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;/app/files or configured base dir&lt;/font&gt;" style="shape=folder;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E6295;fontSize=13;spacing=8;" vertex="1" parent="1">
