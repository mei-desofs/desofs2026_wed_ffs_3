  <diagram id="c4-code-security" name="C4 - Code Security">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1050" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title-c4-code" value="&lt;b&gt;C4 - Code Diagram: Authentication and Security&lt;/b&gt;&lt;br&gt;Implementation-level view of the classes behind JWT authentication, route protection, logout and audit logging." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=20;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="60" y="40" width="1120" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="code-boundary" value="&lt;b&gt;com.cafeteriamanagement.security + controller/config/service&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#C7351D;strokeWidth=4;fontColor=#555555;align=left;verticalAlign=top;spacing=8;container=1;recursiveResize=0;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="100" y="140" width="1180" height="740" as="geometry"/>
        </mxCell>
        <mxCell id="code-auth-controller" value="&lt;b&gt;AuthController&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;POST /api/auth/login&lt;br&gt;POST /api/auth/logout&lt;br&gt;Coordinates login, rate-limit checks and token blocklisting.&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;fontColor=#111111;strokeColor=#B85450;fontSize=13;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="160" y="245" width="240" height="125" as="geometry"/>
        </mxCell>
        <mxCell id="code-security-config" value="&lt;b&gt;SecurityConfig&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;SecurityFilterChain&lt;br&gt;Stateless sessions&lt;br&gt;CORS, HSTS, HTTPS redirect&lt;br&gt;Endpoint RBAC rules&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;fontColor=#111111;strokeColor=#B85450;fontSize=13;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="215" width="250" height="155" as="geometry"/>
        </mxCell>
        <mxCell id="code-jwt-filter" value="&lt;b&gt;JwtRequestFilter&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;OncePerRequestFilter&lt;br&gt;Extracts Bearer token&lt;br&gt;Rejects blocklisted tokens&lt;br&gt;Populates SecurityContext&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;fontColor=#111111;strokeColor=#B85450;fontSize=13;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="890" y="225" width="250" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="code-rate-limiter" value="&lt;b&gt;SimpleRateLimiter&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Tracks failed login attempts by username and IP.&lt;br&gt;5 attempts / 15 minutes.&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;fontColor=#111111;strokeColor=#B85450;fontSize=13;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="160" y="485" width="240" height="105" as="geometry"/>
        </mxCell>
        <mxCell id="code-user-details" value="&lt;b&gt;CustomUserDetailsService&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Loads users from UserRepository for Spring Security authentication.&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;fontColor=#111111;strokeColor=#B85450;fontSize=13;spacing=10;" vertex="1" parent="1">
