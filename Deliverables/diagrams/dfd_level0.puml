@startuml DFD_Level0_Coffeetaria
!theme plain
skinparam shadowing false
skinparam defaultFontSize 13
skinparam rectangleFontSize 13
skinparam rectangleBorderColor #444444
skinparam arrowColor #444444
skinparam arrowFontSize 11

title DFD Level 0 - Context Diagram\nCoffeetaria

' --- External Entities ---
rectangle "Client" as Client #D6EAF8
rectangle "Employee" as Employee #D6EAF8
rectangle "Admin" as Admin #FADBD8

' --- System ---
rectangle "Coffeetaria\n(REST API)" as System #FFF8E1

' --- Data Stores ---
database "PostgreSQL\nDatabase" as DB #D5F5E3
database "File System\n(Reports & Logs)" as FS #D5F5E3

' --- Flows ---
Client   --> System : login / browse menu / place order [HTTPS]
Employee --> System : manage & fulfill orders [HTTPS]
Admin    --> System : manage users, menu & reports [HTTPS]

System --> DB : read / write domain data
System --> FS : write reports & audit logs

@enduml
